source ~/.orbstack/shell/init.zsh 2>/dev/null || :

# Path
HOME=${HOME:-'/Users/jesse'}
path=(
  /opt/homebrew/opt/grep/libexec/gnubin
  /usr/local/sbin
  /usr/local/bin
  $HOME/.local/bin
  $HOME/.composer/vendor/bin
  $path
)

# ZSH Config
export VI_MODE_SET_CURSOR=true
export QUOTING_STYLE=literal

# Default Programs
export EDITOR="nvim"
export LAUNCH_EDITOR="launch-editor-nvim"

# Program Config
export FZF_DEFAULT_OPTS="--style minimal --color 16 --layout=reverse --height 30% --preview='bat -p --color=always {}'"
export FZF_CTRL_R_OPTS="${FZF_CTRL_R_OPTS:+$FZF_CTRL_R_OPTS }--preview  'tldr {2} 2>/dev/null || command -V {2}' --preview-window down:5:hidden:wrap --bind '?:toggle-preview' --header '?:toggle-tldr · enter:select'"
export ZSH_CLEAN_HISTORY_AUTO_CLEAN=true
